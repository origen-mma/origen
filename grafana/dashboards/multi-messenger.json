        "content": "<!DOCTYPE html>\n<html>\n<head>\n<script src=\"https://cdn.plot.ly/plotly-2.27.0.min.js\"></script>\n<style>\n#skymap { width: 100%; height: 680px; }\nbody { margin: 0; font-family: Arial, sans-serif; }\n</style>\n</head>\n<body>\n<div id=\"skymap\"></div>\n<script>\nfetch('http://localhost:8080/api/events')\n  .then(r => r.json())\n  .then(events => {\n    const gwOnly = events.filter(e => (!e.grb_detections || e.grb_detections.length === 0) && (!e.optical_detections || e.optical_detections.length === 0));\n    const multiMessenger = events.filter(e => (e.grb_detections && e.grb_detections.length > 0) || (e.optical_detections && e.optical_detections.length > 0));\n    \n    const makeHover = (e) => {\n      let text = `<b>${e.event_id}</b><br>RA: ${e.ra.toFixed(2)}°<br>Dec: ${e.dec.toFixed(2)}°<br>SNR: ${e.snr.toFixed(1)}<br>FAR: ${e.far.toExponential(2)} Hz`;\n      if (e.grb_detections && e.grb_detections.length > 0) {\n        text += '<br><br><b>GRB:</b>';\n        e.grb_detections.forEach(g => text += `<br>• ${g.instrument}`);\n      }\n      if (e.optical_detections && e.optical_detections.length > 0) {\n        text += '<br><br><b>Optical:</b>';\n        e.optical_detections.forEach(o => text += `<br>• ${o.survey} (mag ${o.magnitude.toFixed(1)})`);\n      }\n      return text;\n    };\n    \n    const traces = [\n      {\n        x: multiMessenger.map(e => e.ra),\n        y: multiMessenger.map(e => e.dec),\n        text: multiMessenger.map(e => e.event_id),\n        hovertemplate: multiMessenger.map(makeHover).map(t => t + '<extra></extra>'),\n        mode: 'markers+text',\n        type: 'scatter',\n        name: 'Multi-Messenger',\n        marker: { size: 20, color: '#ff6b6b', symbol: 'star' },\n        textposition: 'top center',\n        textfont: { size: 10, color: '#ff6b6b' }\n      },\n      {\n        x: gwOnly.map(e => e.ra),\n        y: gwOnly.map(e => e.dec),\n        text: gwOnly.map(e => e.event_id),\n        hovertemplate: gwOnly.map(makeHover).map(t => t + '<extra></extra>'),\n        mode: 'markers+text',\n        type: 'scatter',\n        name: 'GW Only',\n        marker: { size: 15, color: '#00d4ff', symbol: 'circle' },\n        textposition: 'top center',\n        textfont: { size: 10, color: '#00d4ff' }\n      }\n    ];\n    \n    const layout = {\n      title: { text: 'Multi-Messenger Events Sky Map', font: { size: 16 } },\n      xaxis: { title: 'RA (deg)', range: [0, 360], dtick: 60, gridcolor: '#444' },\n      yaxis: { title: 'Dec (deg)', range: [-90, 90], dtick: 30, gridcolor: '#444' },\n      plot_bgcolor: '#1a1a1a',\n      paper_bgcolor: '#1a1a1a',\n      font: { color: '#fff' },\n      hovermode: 'closest',\n      showlegend: true,\n      legend: { x: 0.02, y: 0.98 }\n    };\n    \n    Plotly.newPlot('skymap', traces, layout, {responsive: true});\n    console.log('Loaded ' + events.length + ' events');\n  })\n  .catch(err => {\n    console.error('API Error:', err);\n    document.getElementById('skymap').innerHTML = '<div style=\"color:red;padding:20px;\">Error: Cannot connect to API</div>';\n  });\n</script>\n</body>\n</html>",
        "mode": "html"
      },
